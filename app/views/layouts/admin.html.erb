<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin - IRL2" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>
      if (localStorage.getItem('darkMode') === 'true' || (!localStorage.getItem('darkMode') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="bg-gray-100 dark:bg-gray-950 text-black dark:text-white transition-colors">
    <div class="flex min-h-screen">
      <!-- Mobile sidebar backdrop -->
      <div id="adminSidebarBackdrop" class="hidden fixed inset-0 bg-black/50 z-40 md:hidden"></div>

      <!-- Sidebar -->
      <aside id="adminSidebar" class="w-64 bg-gray-900 dark:bg-gray-950 border-r border-gray-800 fixed inset-y-0 left-0 z-50 -translate-x-full md:translate-x-0 transition-transform duration-200">
        <div class="p-6 border-b border-gray-800 flex items-center justify-between">
          <div>
            <a href="<%= admin_root_path %>" class="font-black text-2xl tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400">IRL2</a>
            <p class="text-xs text-gray-500 uppercase tracking-widest mt-1">Admin Panel</p>
          </div>
          <button id="adminSidebarClose" class="md:hidden p-1 text-gray-400 hover:text-white transition" aria-label="Close sidebar">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <nav class="p-4 space-y-1">
          <%= link_to admin_root_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium uppercase tracking-wider transition #{request.path == admin_root_path ? 'bg-gray-800 text-emerald-400' : 'text-gray-400 hover:text-white hover:bg-gray-800/50'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
            Dashboard
          <% end %>
          <%= link_to admin_tasks_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium uppercase tracking-wider transition #{controller_name == 'tasks' ? 'bg-gray-800 text-emerald-400' : 'text-gray-400 hover:text-white hover:bg-gray-800/50'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            Tasks
          <% end %>
          <%= link_to admin_users_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium uppercase tracking-wider transition #{controller_name == 'users' ? 'bg-gray-800 text-emerald-400' : 'text-gray-400 hover:text-white hover:bg-gray-800/50'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/></svg>
            Users
          <% end %>
          <%= link_to admin_comments_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium uppercase tracking-wider transition #{controller_name == 'comments' ? 'bg-gray-800 text-emerald-400' : 'text-gray-400 hover:text-white hover:bg-gray-800/50'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
            Comments
          <% end %>
          <%= link_to admin_submissions_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium uppercase tracking-wider transition #{controller_name == 'submissions' ? 'bg-gray-800 text-emerald-400' : 'text-gray-400 hover:text-white hover:bg-gray-800/50'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
            Submissions
          <% end %>
        </nav>
        <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-gray-800">
          <%= link_to root_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-gray-800/50 transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12"/></svg>
            Back to Site
          <% end %>
          <div class="px-4 py-2 text-xs text-gray-600">
            Signed in as <span class="text-gray-400"><%= current_user.email.split('@').first %></span>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 md:ml-64 min-w-0">
        <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 px-4 md:px-8 py-4 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <button id="adminSidebarOpen" class="md:hidden p-2 -ml-2 text-gray-500 hover:text-gray-900 dark:hover:text-white transition" aria-label="Open sidebar">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
            </button>
            <h1 class="text-lg font-bold text-gray-900 dark:text-white uppercase tracking-wider truncate"><%= yield :page_title %></h1>
          </div>
          <div class="flex items-center gap-4">
            <button id="adminDarkModeToggle" class="px-3 py-2 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition text-xl" aria-label="Toggle dark mode">
              <span class="dark:hidden">🌙</span>
              <span class="hidden dark:inline">☀️</span>
            </button>
          </div>
        </header>
        <div class="p-4 md:p-8">
          <% if notice.present? %>
            <div class="mb-6">
              <div class="p-4 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 rounded-lg">
                <p class="text-sm font-bold text-emerald-800 dark:text-emerald-200 uppercase tracking-wide"><%= notice %></p>
              </div>
            </div>
          <% end %>
          <% if alert.present? %>
            <div class="mb-6">
              <div class="p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg">
                <p class="text-sm font-bold text-red-800 dark:text-red-200 uppercase tracking-wide"><%= alert %></p>
              </div>
            </div>
          <% end %>
          <%= yield %>
        </div>
      </main>
    </div>
    <script>
      function initAdminControls() {
        // Dark mode toggle
        const toggle = document.getElementById('adminDarkModeToggle');
        if (toggle) {
          const newToggle = toggle.cloneNode(true);
          toggle.parentNode.replaceChild(newToggle, toggle);
          newToggle.addEventListener('click', function() {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('darkMode', isDark);
          });
        }

        // Sidebar toggle
        const sidebar = document.getElementById('adminSidebar');
        const backdrop = document.getElementById('adminSidebarBackdrop');
        const openBtn = document.getElementById('adminSidebarOpen');
        const closeBtn = document.getElementById('adminSidebarClose');

        function openSidebar() {
          sidebar.classList.remove('-translate-x-full');
          backdrop.classList.remove('hidden');
        }
        function closeSidebar() {
          sidebar.classList.add('-translate-x-full');
          backdrop.classList.add('hidden');
        }

        if (openBtn) {
          const newOpen = openBtn.cloneNode(true);
          openBtn.parentNode.replaceChild(newOpen, openBtn);
          newOpen.addEventListener('click', openSidebar);
        }
        if (closeBtn) {
          const newClose = closeBtn.cloneNode(true);
          closeBtn.parentNode.replaceChild(newClose, closeBtn);
          newClose.addEventListener('click', closeSidebar);
        }
        if (backdrop) {
          backdrop.addEventListener('click', closeSidebar);
        }

        // Close sidebar on nav link click (mobile)
        if (sidebar) {
          sidebar.querySelectorAll('nav a').forEach(function(link) {
            link.addEventListener('click', function() {
              if (window.innerWidth < 768) closeSidebar();
            });
          });
        }
      }

      document.addEventListener('DOMContentLoaded', initAdminControls);
      document.addEventListener('turbo:load', initAdminControls);
    </script>
  </body>
</html>
