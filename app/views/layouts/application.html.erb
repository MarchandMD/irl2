<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Irl2" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>
      if (localStorage.getItem('darkMode') === 'true' || (!localStorage.getItem('darkMode') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="bg-white dark:bg-gray-950 text-black dark:text-white transition-colors">
    <header id="mainHeader" class="fixed top-0 left-0 right-0 bg-gray-900 dark:bg-gray-950 border-b border-gray-800 dark:border-gray-900 z-50 transition-all duration-300">
      <nav id="mainNav" class="container mx-auto px-5 py-4 flex items-center justify-between transition-all duration-300">
        <!-- Logo -->
        <div class="flex items-center space-x-4">
          <a href="/" class="font-black text-2xl tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400 hover:from-blue-300 hover:to-emerald-300 transition">IRL2</a>
        </div>

        <!-- Desktop nav (hidden on mobile) -->
        <div class="hidden md:flex items-center space-x-6">
          <a href="/" class="text-gray-300 hover:text-white font-medium uppercase tracking-wider text-sm transition">Home</a>
          <a href="/users" class="text-gray-300 hover:text-white font-medium uppercase tracking-wider text-sm transition">Users</a>
          <a href="/tasks" class="text-gray-300 hover:text-white font-medium uppercase tracking-wider text-sm transition">Tasks</a>
          <a href="/groups" class="text-gray-300 hover:text-white font-medium uppercase tracking-wider text-sm transition">Groups</a>
          <a href="/submissions" class="text-gray-300 hover:text-white font-medium uppercase tracking-wider text-sm transition">Submissions</a>
          <a href="/channels" class="text-gray-300 hover:text-white font-medium uppercase tracking-wider text-sm transition">Chat</a>
          <a href="/about" class="text-gray-300 hover:text-white font-medium uppercase tracking-wider text-sm transition">About</a>
          <button id="darkModeToggle" class="px-3 py-2 text-gray-300 hover:text-white transition text-xl" aria-label="Toggle dark mode">
            <span class="dark:hidden">🌙</span>
            <span class="hidden dark:inline">☀️</span>
          </button>
          <% if user_signed_in? %>
            <div class="relative" id="userMenu">
              <button id="userMenuButton" class="flex items-center gap-2 px-4 py-2 text-gray-300 hover:text-white font-medium text-sm transition">
                <% if current_user.profile_photo.attached? %>
                  <%= image_tag current_user.profile_photo,
                      class: "w-8 h-8 rounded-full object-cover border-2 border-emerald-400" %>
                <% else %>
                  <span class="text-emerald-400">👤</span>
                <% end %>
                <span><%= current_user.email.split('@').first %></span>
                <span class="text-xs">▼</span>
              </button>
              <div id="userMenuDropdown" class="hidden absolute right-0 mt-2 w-48 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 z-50">
                <div class="py-1">
                  <%= link_to "Profile", user_path(current_user), class: "block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700" %>
                  <%= link_to "Settings", edit_user_registration_path, class: "block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700" %>
                  <% if current_user.admin? %>
                    <%= link_to "Admin", admin_root_path, class: "block px-4 py-2 text-sm text-emerald-600 dark:text-emerald-400 hover:bg-gray-100 dark:hover:bg-gray-700 font-medium" %>
                  <% end %>
                  <%= button_to "Log Out", destroy_user_session_path, method: :delete, class: "w-full text-left px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-gray-100 dark:hover:bg-gray-700", form: { data: { turbo: false } } %>
                </div>
              </div>
            </div>
          <% else %>
            <a href="/users/sign_in" class="text-gray-300 hover:text-white font-medium uppercase tracking-wider text-sm transition">Log In</a>
            <a href="/users/sign_up" class="px-4 py-2 bg-emerald-500 text-black font-bold text-xs uppercase tracking-wider hover:bg-emerald-400 transition rounded">Join</a>
          <% end %>
        </div>

        <!-- Mobile: dark mode + hamburger -->
        <div class="flex items-center gap-2 md:hidden">
          <button id="darkModeToggleMobile" class="px-3 py-2 text-gray-300 hover:text-white transition text-xl" aria-label="Toggle dark mode">
            <span class="dark:hidden">🌙</span>
            <span class="hidden dark:inline">☀️</span>
          </button>
          <button id="hamburgerBtn" class="p-2 text-gray-300 hover:text-white transition" aria-label="Open menu">
            <svg id="hamburgerIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg id="closeIcon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </nav>

      <!-- Mobile menu panel -->
      <div id="mobileMenu" class="hidden md:hidden border-t border-gray-800 dark:border-gray-900 bg-gray-900 dark:bg-gray-950">
        <div class="container mx-auto px-5 py-4 flex flex-col space-y-1">
          <a href="/" class="block px-3 py-3 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg font-medium uppercase tracking-wider text-sm transition">Home</a>
          <a href="/users" class="block px-3 py-3 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg font-medium uppercase tracking-wider text-sm transition">Users</a>
          <a href="/tasks" class="block px-3 py-3 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg font-medium uppercase tracking-wider text-sm transition">Tasks</a>
          <a href="/groups" class="block px-3 py-3 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg font-medium uppercase tracking-wider text-sm transition">Groups</a>
          <a href="/submissions" class="block px-3 py-3 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg font-medium uppercase tracking-wider text-sm transition">Submissions</a>
          <a href="/channels" class="block px-3 py-3 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg font-medium uppercase tracking-wider text-sm transition">Chat</a>
          <a href="/about" class="block px-3 py-3 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg font-medium uppercase tracking-wider text-sm transition">About</a>
          <div class="border-t border-gray-800 dark:border-gray-900 pt-3 mt-2">
            <% if user_signed_in? %>
              <div class="flex items-center gap-3 px-3 py-3">
                <% if current_user.profile_photo.attached? %>
                  <%= image_tag current_user.profile_photo, class: "w-8 h-8 rounded-full object-cover border-2 border-emerald-400" %>
                <% else %>
                  <span class="text-emerald-400 text-lg">👤</span>
                <% end %>
                <span class="text-white font-medium text-sm"><%= current_user.email.split('@').first %></span>
              </div>
              <%= link_to "Profile", user_path(current_user), class: "block px-3 py-3 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg font-medium uppercase tracking-wider text-sm transition" %>
              <%= link_to "Settings", edit_user_registration_path, class: "block px-3 py-3 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg font-medium uppercase tracking-wider text-sm transition" %>
              <% if current_user.admin? %>
                <%= link_to "Admin", admin_root_path, class: "block px-3 py-3 text-emerald-400 hover:text-emerald-300 hover:bg-gray-800 rounded-lg font-medium uppercase tracking-wider text-sm transition" %>
              <% end %>
              <%= button_to "Log Out", destroy_user_session_path, method: :delete, class: "w-full text-left px-3 py-3 text-red-400 hover:text-red-300 hover:bg-gray-800 rounded-lg font-medium uppercase tracking-wider text-sm transition", form: { data: { turbo: false } } %>
            <% else %>
              <a href="/users/sign_in" class="block px-3 py-3 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg font-medium uppercase tracking-wider text-sm transition">Log In</a>
              <a href="/users/sign_up" class="block px-3 py-3 mt-1 bg-emerald-500 text-black text-center font-bold text-xs uppercase tracking-wider hover:bg-emerald-400 transition rounded-lg">Join</a>
            <% end %>
          </div>
        </div>
      </div>
    </header>
    <script>
      function initializeHeaderControls() {
        // Dark mode toggle (desktop)
        const darkModeToggle = document.getElementById('darkModeToggle');
        if (darkModeToggle) {
          const newToggle = darkModeToggle.cloneNode(true);
          darkModeToggle.parentNode.replaceChild(newToggle, darkModeToggle);
          newToggle.addEventListener('click', function() {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('darkMode', isDark);
          });
        }

        // Dark mode toggle (mobile)
        const darkModeToggleMobile = document.getElementById('darkModeToggleMobile');
        if (darkModeToggleMobile) {
          const newToggleMobile = darkModeToggleMobile.cloneNode(true);
          darkModeToggleMobile.parentNode.replaceChild(newToggleMobile, darkModeToggleMobile);
          newToggleMobile.addEventListener('click', function() {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('darkMode', isDark);
          });
        }

        // Hamburger menu
        const hamburgerBtn = document.getElementById('hamburgerBtn');
        const mobileMenu = document.getElementById('mobileMenu');
        const hamburgerIcon = document.getElementById('hamburgerIcon');
        const closeIcon = document.getElementById('closeIcon');

        if (hamburgerBtn && mobileMenu) {
          const newHamburger = hamburgerBtn.cloneNode(true);
          hamburgerBtn.parentNode.replaceChild(newHamburger, hamburgerBtn);

          newHamburger.addEventListener('click', function() {
            const menu = document.getElementById('mobileMenu');
            const hIcon = document.getElementById('hamburgerIcon');
            const cIcon = document.getElementById('closeIcon');
            const isOpen = !menu.classList.contains('hidden');

            if (isOpen) {
              menu.classList.add('hidden');
              hIcon.classList.remove('hidden');
              cIcon.classList.add('hidden');
            } else {
              menu.classList.remove('hidden');
              hIcon.classList.add('hidden');
              cIcon.classList.remove('hidden');
            }
          });
        }

        // Close mobile menu on link click
        const mobileMenuEl = document.getElementById('mobileMenu');
        if (mobileMenuEl) {
          mobileMenuEl.querySelectorAll('a').forEach(function(link) {
            link.addEventListener('click', function() {
              document.getElementById('mobileMenu').classList.add('hidden');
              document.getElementById('hamburgerIcon').classList.remove('hidden');
              document.getElementById('closeIcon').classList.add('hidden');
            });
          });
        }

        // Desktop user menu dropdown
        const userMenuButton = document.getElementById('userMenuButton');
        const userMenuDropdown = document.getElementById('userMenuDropdown');

        if (userMenuButton && userMenuDropdown) {
          const newButton = userMenuButton.cloneNode(true);
          userMenuButton.parentNode.replaceChild(newButton, userMenuButton);

          newButton.addEventListener('click', function(e) {
            e.stopPropagation();
            document.getElementById('userMenuDropdown').classList.toggle('hidden');
          });

          document.addEventListener('click', function(e) {
            const userMenu = document.getElementById('userMenu');
            if (userMenu && !userMenu.contains(e.target)) {
              document.getElementById('userMenuDropdown').classList.add('hidden');
            }
          });
        }
      }

      // Initialize on initial page load
      initializeHeaderControls();

      // Re-initialize after Turbo Drive navigation
      document.addEventListener('turbo:load', initializeHeaderControls);

      // Handle scroll for sticky nav
      let lastScrollTop = 0;
      function handleNavScroll() {
        const nav = document.getElementById('mainNav');
        if (!nav) return;

        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

        if (scrollTop > 50) {
          nav.classList.remove('py-4');
          nav.classList.add('py-2');
        } else {
          nav.classList.remove('py-2');
          nav.classList.add('py-4');
        }

        lastScrollTop = scrollTop;
      }

      // Initialize scroll handler
      window.addEventListener('scroll', handleNavScroll);
      document.addEventListener('turbo:load', () => {
        handleNavScroll(); // Check initial state
      });
    </script>
    <main class="container mx-auto mt-28 px-5">
      <% if notice.present? %>
        <div class="mb-6 max-w-4xl mx-auto">
          <div class="p-4 bg-gradient-to-r from-emerald-50 to-blue-50 dark:from-emerald-900/20 dark:to-blue-900/20 border-l-4 border-emerald-500 rounded-lg shadow-md">
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 mt-0.5">
                <svg class="w-6 h-6 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div class="flex-1">
                <p class="text-sm font-bold text-emerald-800 dark:text-emerald-200 uppercase tracking-wide"><%= notice %></p>
              </div>
              <button onclick="this.closest('.mb-6').remove()" class="flex-shrink-0 text-emerald-600 dark:text-emerald-400 hover:text-emerald-800 dark:hover:text-emerald-200 transition">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-6 max-w-4xl mx-auto">
          <div class="p-4 bg-gradient-to-r from-red-50 to-orange-50 dark:from-red-900/20 dark:to-orange-900/20 border-l-4 border-red-500 rounded-lg shadow-md">
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 mt-0.5">
                <svg class="w-6 h-6 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div class="flex-1">
                <p class="text-sm font-bold text-red-800 dark:text-red-200 uppercase tracking-wide"><%= alert %></p>
              </div>
              <button onclick="this.closest('.mb-6').remove()" class="flex-shrink-0 text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-200 transition">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
