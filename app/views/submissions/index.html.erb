<div class="max-w-6xl mx-auto">
  <div class="mb-8">
    <h1 class="text-4xl font-black tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400 mb-2">
      Submissions
    </h1>
    <p class="text-gray-600 dark:text-gray-400">All task submissions from the community</p>
  </div>

  <div class="grid gap-6">
    <% @submissions.each do |submission| %>
      <div class="bg-white dark:bg-gray-900 rounded-lg shadow-md border border-gray-200 dark:border-gray-800 p-6 hover:shadow-lg transition">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-3">
              <% if submission.user.profile_photo.attached? %>
                <%= image_tag submission.user.profile_photo,
                    class: "w-10 h-10 rounded-full object-cover border-2 border-emerald-400" %>
              <% else %>
                <span class="text-2xl">👤</span>
              <% end %>
              <div>
                <%= link_to user_path(submission.user), class: "font-bold text-gray-900 dark:text-white hover:text-emerald-500 dark:hover:text-emerald-400 transition" do %>
                  <%= submission.user.email.split('@').first %>
                <% end %>
                <p class="text-xs text-gray-500 dark:text-gray-400">
                  <%= time_ago_in_words(submission.created_at) %> ago
                </p>
              </div>
            </div>

            <div class="mb-3">
              <%= link_to task_path(submission.task), class: "text-lg font-bold text-gray-900 dark:text-white hover:text-emerald-500 dark:hover:text-emerald-400 transition" do %>
                <%= submission.task.title %>
              <% end %>
              <% if submission.task.description.present? %>
                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
                  <%= submission.task.description %>
                </p>
              <% end %>
            </div>

            <% if submission.submission_text.present? %>
              <div class="bg-gray-50 dark:bg-gray-800 rounded p-3 text-sm text-gray-700 dark:text-gray-300">
                <%= submission.submission_text %>
              </div>
            <% end %>
          </div>

          <div class="flex flex-col items-end gap-2">
            <span class="px-3 py-1 bg-emerald-100 dark:bg-emerald-900/30 text-emerald-800 dark:text-emerald-400 text-xs font-bold rounded-full uppercase">
              <%= submission.task.status %>
            </span>
          </div>
        </div>
      </div>
    <% end %>

    <% if @submissions.empty? %>
      <div class="text-center py-12">
        <p class="text-gray-500 dark:text-gray-400 text-lg">No submissions yet. Be the first to complete a task!</p>
      </div>
    <% end %>
  </div>
</div>
