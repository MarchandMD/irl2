<div class="w-full max-w-5xl mx-auto">
  <!-- Back Navigation -->
  <div class="mb-6">
    <%= link_to @task, class: "inline-flex items-center gap-2 text-gray-600 dark:text-gray-400 hover:text-emerald-600 dark:hover:text-emerald-400 transition font-medium" do %>
      <span>←</span>
      <span>Back to Task</span>
    <% end %>
  </div>

  <!-- Edit Submission Form -->
  <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-8">
    <h1 class="text-3xl font-black text-gray-900 dark:text-white mb-6 uppercase tracking-tight">
      Edit Submission
    </h1>

    <%= form_with model: @submission, url: task_submission_path(@task, @submission), method: :patch, multipart: true, data: { controller: "file-upload-preview" } do |f| %>
      <!-- Text Area -->
      <div class="mb-6">
        <label class="block text-sm font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wide mb-2">
          Description
        </label>
        <%= f.text_area :submission_text, rows: 6, class: "w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700 dark:text-white", placeholder: "Describe your solution..." %>
        <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
          💡 Explain approach, challenges faced, and key learnings
        </p>
      </div>

      <!-- Current Media -->
      <% if @submission.submission_media.attached? %>
        <div class="mb-6">
          <label class="block text-sm font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wide mb-2">
            Current Media
          </label>
          <div class="grid grid-cols-2 gap-4 mb-4" id="current-media-grid">
            <% @submission.submission_media.each do |media| %>
              <div class="relative group" id="media-<%= media.id %>" data-media-id="<%= media.id %>">
                <% if media.content_type.start_with?('image/') %>
                  <%= image_tag media, class: "w-full rounded-lg border border-gray-200 dark:border-gray-700" %>
                <% elsif media.content_type.start_with?('video/') %>
                  <video controls class="w-full rounded-lg border border-gray-200 dark:border-gray-700">
                    <%= tag.source src: url_for(media), type: media.content_type %>
                  </video>
                <% end %>
                <button type="button" onclick="markMediaForRemoval(<%= media.id %>)" class="absolute top-2 right-2 w-8 h-8 bg-red-500 hover:bg-red-600 text-white rounded-full flex items-center justify-center font-bold shadow-lg transition opacity-0 group-hover:opacity-100">
                  ×
                </button>
              </div>
            <% end %>
          </div>
          <p class="text-sm text-gray-500 dark:text-gray-400">
            ℹ️ Hover over media to see delete button. Marked media will be removed when form is submitted.
          </p>
        </div>
      <% end %>

      <script>
        function markMediaForRemoval(mediaId) {
          const mediaElement = document.getElementById('media-' + mediaId);
          const isMarked = mediaElement.classList.contains('marked-for-removal');

          if (isMarked) {
            // Unmark for removal
            mediaElement.classList.remove('marked-for-removal');
            mediaElement.innerHTML = mediaElement.getAttribute('data-original-content');
            // Remove hidden input
            const hiddenInput = document.getElementById('remove-media-' + mediaId);
            if (hiddenInput) hiddenInput.remove();
          } else {
            // Store original content
            mediaElement.setAttribute('data-original-content', mediaElement.innerHTML);
            // Mark for removal with placeholder
            mediaElement.classList.add('marked-for-removal');
            mediaElement.innerHTML = `
              <div class="w-full h-full min-h-[200px] bg-gray-100 dark:bg-gray-700 rounded-lg border-2 border-dashed border-red-500 flex flex-col items-center justify-center p-4 cursor-pointer" onclick="markMediaForRemoval(${mediaId})" title="Click to undo">
                <span class="text-4xl">📷</span>
              </div>
            `;
            // Add hidden input to track removal
            const form = document.querySelector('form');
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'user_task[remove_media_ids][]';
            input.value = mediaId;
            input.id = 'remove-media-' + mediaId;
            form.appendChild(input);
          }
        }
      </script>

      <!-- File Upload -->
      <div class="mb-6">
        <label class="block text-sm font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wide mb-2">
          Add Media (Photos/Videos)
        </label>
        <%= f.file_field :submission_media, multiple: true, accept: "image/png,image/jpg,image/jpeg,image/gif,image/webp,video/mp4,video/quicktime,video/x-msvideo", class: "w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700 dark:text-white file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 dark:file:bg-blue-900 dark:file:text-blue-300", data: { action: "change->file-upload-preview#preview" } %>
        <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
          📸 Upload screenshots, photos, or videos (Images: max 5MB, Videos: max 50MB)
        </p>
      </div>

      <!-- Preview Area -->
      <div id="file-preview" data-file-upload-preview-target="preview" class="mb-6 hidden">
        <label class="block text-sm font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wide mb-2">
          New Media Preview
        </label>
        <div class="grid grid-cols-2 gap-4" data-file-upload-preview-target="container">
        </div>
      </div>

      <!-- Requirement Notice -->
      <div class="mb-6 p-4 bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800 rounded-lg">
        <p class="text-sm text-blue-800 dark:text-blue-300">
          ℹ️ <strong>Note:</strong> Include either text or media (or both) for submission.
        </p>
      </div>

      <!-- Action Buttons -->
      <div class="flex gap-3">
        <%= f.submit "Update Submission", class: "flex-1 px-6 py-3 bg-blue-500 text-white font-bold text-sm uppercase tracking-wider hover:bg-blue-400 transition rounded cursor-pointer" %>
        <%= link_to "Cancel", @task, class: "px-6 py-3 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-bold text-sm uppercase tracking-wider hover:bg-gray-50 dark:hover:bg-gray-700 transition rounded text-center" %>
      </div>
    <% end %>
  </div>
</div>
