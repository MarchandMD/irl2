<%= turbo_stream_from @channel %>

<div class="w-full max-w-4xl mx-auto flex flex-col" style="height: calc(100vh - 10rem);" data-controller="chat">
  <!-- Header -->
  <div class="mb-4">
    <h1 class="text-4xl font-black uppercase tracking-tight text-gray-900 dark:text-white mb-1">
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400">#</span> <%= @channel.name %>
    </h1>
    <p class="text-gray-500 dark:text-gray-400 text-sm"><%= @channel.description %></p>
  </div>

  <!-- Messages area -->
  <div
    id="messages"
    class="flex-1 overflow-y-auto space-y-1 p-4 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl mb-4 scroll-smooth"
    data-chat-target="messages"
  >
    <% if @messages.empty? %>
      <div class="flex items-center justify-center h-full">
        <p class="text-gray-400 dark:text-gray-600 text-sm uppercase tracking-wider font-medium">No messages yet — start the conversation</p>
      </div>
    <% else %>
      <% @messages.each do |message| %>
        <%= render partial: "messages/message", locals: { message: message } %>
      <% end %>
    <% end %>
  </div>

  <!-- Message input -->
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-3">
    <%= form_with model: [@channel, @message], id: "message-form", class: "flex items-center gap-3", data: { chat_target: "form", action: "turbo:submit-end->chat#clearInput" } do |f| %>
      <%= f.text_field :content,
          placeholder: "Type a message...",
          autofocus: true,
          autocomplete: "off",
          data: { chat_target: "input" },
          class: "flex-1 px-4 py-3 bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-200 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent text-sm" %>
      <%= f.submit "Send",
          class: "px-6 py-3 bg-emerald-500 hover:bg-emerald-400 text-black font-bold text-xs uppercase tracking-wider rounded-lg transition cursor-pointer shadow-sm hover:shadow-[0_0_12px_rgba(16,185,129,0.4)]" %>
    <% end %>
  </div>
</div>
