<div class="w-full max-w-6xl mx-auto">
  <div class="grid md:grid-cols-2 gap-8 items-center">
    <!-- Left Side: Hero/Branding -->
    <div class="hidden md:block">
      <div class="relative py-16 px-8 overflow-hidden bg-gradient-to-br from-gray-900 via-blue-900 to-emerald-900 rounded-3xl shadow-2xl">
        <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')]"></div>
        <div class="relative z-10">
          <h1 class="text-5xl font-black uppercase tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400 mb-6">
            Join the Network
          </h1>
          <p class="text-xl text-gray-300 font-light leading-relaxed mb-8">
            Become a member in the world's most creative reality game. Design challenges, complete missions, and transform your city into a playground.
          </p>

          <div class="space-y-4 text-gray-300">
            <div class="flex items-start gap-3">
              <span class="text-2xl flex-shrink-0">🎯</span>
              <div>
                <h3 class="font-bold text-white mb-1">Create Missions</h3>
                <p class="text-sm text-gray-400">Design imaginative real-world challenges for the community</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <span class="text-2xl flex-shrink-0">⚡️</span>
              <div>
                <h3 class="font-bold text-white mb-1">Complete Tasks</h3>
                <p class="text-sm text-gray-400">Accept challenges and document your adventures</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <span class="text-2xl flex-shrink-0">🏆</span>
              <div>
                <h3 class="font-bold text-white mb-1">Rise Through Ranks</h3>
                <p class="text-sm text-gray-400">Build reputation and unlock legendary status</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Side: Registration Form -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-8 shadow-xl">
      <div class="mb-8">
        <h2 class="text-3xl font-black uppercase tracking-tight text-gray-900 dark:text-white mb-2">
          Create Account
        </h2>
        <p class="text-gray-600 dark:text-gray-400">
          Start your journey. The city awaits.
        </p>
      </div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-6">
          <!-- Email Field -->
          <div>
            <%= f.label :email, class: "block text-sm font-bold uppercase tracking-wide text-gray-700 dark:text-gray-300 mb-2" %>
            <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                placeholder: "email_address@email.com",
                class: "w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-900 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition" %>
          </div>

          <!-- Password Field -->
          <div>
            <%= f.label :password, class: "block text-sm font-bold uppercase tracking-wide text-gray-700 dark:text-gray-300 mb-2" do %>
              Password
              <% if @minimum_password_length %>
                <span class="text-xs font-normal normal-case text-gray-500 dark:text-gray-400">
                  (<%= @minimum_password_length %> characters minimum)
                </span>
              <% end %>
            <% end %>
            <%= f.password_field :password,
                autocomplete: "new-password",
                placeholder: "Enter secure password",
                class: "w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-900 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition" %>
          </div>

          <!-- Password Confirmation Field -->
          <div>
            <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-bold uppercase tracking-wide text-gray-700 dark:text-gray-300 mb-2" %>
            <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                placeholder: "Re-enter password",
                class: "w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-900 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition" %>
          </div>

          <!-- Submit Button -->
          <div class="pt-4">
            <%= f.submit "Join IRL2", class: "w-full px-6 py-4 bg-emerald-500 text-black font-bold text-lg uppercase tracking-wider hover:bg-emerald-400 transition rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 cursor-pointer" %>
          </div>
        </div>
      <% end %>

      <%- if devise_mapping.omniauthable? %>
        <div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
          <p class="text-center text-sm text-gray-500 dark:text-gray-400 mb-4 uppercase tracking-wide font-bold">Or sign up with</p>
          <%- resource_class.omniauth_providers.each do |provider| %>
            <%= button_to omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "w-full flex items-center justify-center gap-3 px-6 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-900 text-gray-700 dark:text-gray-200 font-semibold hover:bg-gray-50 dark:hover:bg-gray-800 transition shadow-sm" do %>
              <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
              Sign up with Google
            <% end %>
          <% end %>
        </div>
      <% end %>

      <!-- Links -->
            <%= link_to "Log In", new_session_path(resource_name), class: "font-bold text-emerald-600 dark:text-emerald-400 hover:text-emerald-500 dark:hover:text-emerald-300 transition" %>
          </p>

          <div class="flex flex-wrap justify-center gap-4 text-xs">
            <%= link_to "Didn't receive confirmation?", new_confirmation_path(resource_name), class: "text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition" if devise_mapping.confirmable? && controller_name != 'confirmations' %>
            <%= link_to "Didn't receive unlock?", new_unlock_path(resource_name), class: "text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition" if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile Hero (visible only on mobile) -->
    <div class="md:hidden mb-8 py-12 px-6 text-center bg-gradient-to-br from-gray-900 via-blue-900 to-emerald-900 rounded-3xl shadow-2xl">
      <h1 class="text-4xl font-black uppercase tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400 mb-4">
        Join the Network
      </h1>
      <p class="text-lg text-gray-300 font-light">
        Transform your city into a playground
      </p>
    </div>
  </div>
</div>
