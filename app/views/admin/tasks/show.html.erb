<% content_for(:page_title, @task.title.truncate(50)) %>

<div class="mb-6">
  <%= link_to "← Back to Tasks", admin_tasks_path, class: "text-sm font-bold text-emerald-500 hover:text-emerald-400 uppercase tracking-wider" %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <!-- Main Content -->
  <div class="lg:col-span-2 space-y-6">
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg p-6">
      <div class="flex items-start justify-between mb-4">
        <h2 class="text-2xl font-black text-gray-900 dark:text-white"><%= @task.title %></h2>
        <% status_classes = { 'open' => 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400', 'in_progress' => 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400', 'completed' => 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400', 'closed' => 'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400' } %>
        <span class="px-2 py-1 text-xs font-bold rounded uppercase tracking-wider <%= status_classes[@task.status] %>"><%= @task.status.humanize %></span>
      </div>
      <div class="prose dark:prose-invert max-w-none text-gray-700 dark:text-gray-300">
        <p><%= @task.description %></p>
      </div>
    </div>

    <!-- Comments -->
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-800">
        <h3 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider">Comments (<%= @task.comments.count %>)</h3>
      </div>
      <div class="divide-y divide-gray-200 dark:divide-gray-800">
        <% @task.comments.includes(:user).each do |comment| %>
          <div class="px-6 py-4">
            <div class="flex items-center justify-between mb-2">
              <p class="text-sm font-medium text-gray-900 dark:text-white"><%= comment.user.email.split('@').first %></p>
              <div class="flex items-center gap-3">
                <p class="text-xs text-gray-500"><%= time_ago_in_words(comment.created_at) %> ago</p>
                <%= button_to "Delete", admin_comment_path(comment), method: :delete, class: "text-xs font-bold text-red-500 hover:text-red-400 uppercase tracking-wider", form: { data: { turbo_confirm: "Delete this comment?" } } %>
              </div>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400"><%= comment.content %></p>
          </div>
        <% end %>
        <% if @task.comments.empty? %>
          <div class="px-6 py-8 text-center text-gray-500 text-sm">No comments.</div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- Actions -->
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg p-6 space-y-3">
      <h3 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Actions</h3>
      <%= link_to "Edit Task", edit_admin_task_path(@task), class: "block w-full text-center px-4 py-2 bg-emerald-500 text-black font-bold text-xs uppercase tracking-wider hover:bg-emerald-400 transition rounded-lg" %>
      <%= link_to "View on Site", task_path(@task), class: "block w-full text-center px-4 py-2 border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 font-bold text-xs uppercase tracking-wider hover:bg-gray-50 dark:hover:bg-gray-800 transition rounded-lg", target: "_blank" %>
      <%= button_to "Delete Task", admin_task_path(@task), method: :delete, class: "w-full px-4 py-2 bg-red-600 text-white font-bold text-xs uppercase tracking-wider hover:bg-red-500 transition rounded-lg", form: { data: { turbo_confirm: "Are you sure you want to permanently delete this task?" } } %>
    </div>

    <!-- Details -->
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg p-6">
      <h3 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Details</h3>
      <dl class="space-y-3">
        <div>
          <dt class="text-xs font-bold text-gray-500 uppercase tracking-wider">Author</dt>
          <dd class="text-sm text-gray-900 dark:text-white mt-1"><%= link_to @task.user.email, admin_user_path(@task.user), class: "text-emerald-500 hover:text-emerald-400" %></dd>
        </div>
        <div>
          <dt class="text-xs font-bold text-gray-500 uppercase tracking-wider">Group</dt>
          <dd class="text-sm text-gray-900 dark:text-white mt-1"><%= @task.recommended_group || "None" %></dd>
        </div>
        <div>
          <dt class="text-xs font-bold text-gray-500 uppercase tracking-wider">Upvotes</dt>
          <dd class="text-sm text-gray-900 dark:text-white mt-1"><%= @task.upvotes_count %></dd>
        </div>
        <div>
          <dt class="text-xs font-bold text-gray-500 uppercase tracking-wider">Submissions</dt>
          <dd class="text-sm text-gray-900 dark:text-white mt-1"><%= @task.submissions_count %></dd>
        </div>
        <div>
          <dt class="text-xs font-bold text-gray-500 uppercase tracking-wider">Bookmarks</dt>
          <dd class="text-sm text-gray-900 dark:text-white mt-1"><%= @task.bookmarks_count %></dd>
        </div>
        <div>
          <dt class="text-xs font-bold text-gray-500 uppercase tracking-wider">Created</dt>
          <dd class="text-sm text-gray-900 dark:text-white mt-1"><%= @task.created_at.strftime("%b %d, %Y at %I:%M %p") %></dd>
        </div>
      </dl>
    </div>
  </div>
</div>
