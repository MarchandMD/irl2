<% content_for(:page_title, "Comments") %>

<div class="flex items-center justify-between mb-6">
  <div>
    <p class="text-sm text-gray-500 dark:text-gray-400"><%= @comments.count %> comments total</p>
  </div>
</div>

<div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg overflow-hidden overflow-x-auto">
  <table class="w-full min-w-[600px]">
    <thead>
      <tr class="border-b border-gray-200 dark:border-gray-800">
        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Author</th>
        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Content</th>
        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">On</th>
        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Date</th>
        <th class="px-6 py-3 text-right text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
      <% @comments.each do |comment| %>
        <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition">
          <td class="px-6 py-4">
            <%= link_to comment.user.email.split('@').first, admin_user_path(comment.user), class: "text-sm font-medium text-gray-900 dark:text-white hover:text-emerald-500 transition" %>
          </td>
          <td class="px-6 py-4">
            <p class="text-sm text-gray-600 dark:text-gray-400 max-w-md truncate"><%= comment.content %></p>
          </td>
          <td class="px-6 py-4">
            <% if comment.commentable.is_a?(Task) %>
              <%= link_to comment.commentable.title.truncate(30), admin_task_path(comment.commentable), class: "text-sm text-emerald-500 hover:text-emerald-400" %>
            <% elsif comment.commentable.is_a?(UserTask) %>
              <span class="text-sm text-gray-500">Submission #<%= comment.commentable_id %></span>
            <% else %>
              <span class="text-sm text-gray-500"><%= comment.commentable_type %> #<%= comment.commentable_id %></span>
            <% end %>
          </td>
          <td class="px-6 py-4">
            <p class="text-sm text-gray-500"><%= time_ago_in_words(comment.created_at) %> ago</p>
          </td>
          <td class="px-6 py-4 text-right">
            <%= button_to "Delete", admin_comment_path(comment), method: :delete, class: "px-3 py-1 text-xs font-bold text-red-600 dark:text-red-400 hover:text-red-500 uppercase tracking-wider", form: { data: { turbo_confirm: "Delete this comment?" } } %>
          </td>
        </tr>
      <% end %>
      <% if @comments.empty? %>
        <tr>
          <td colspan="5" class="px-6 py-12 text-center text-gray-500 text-sm">No comments found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
