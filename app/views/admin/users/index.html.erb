<% content_for(:page_title, "Users") %>

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
  <div>
    <p class="text-sm text-gray-500 dark:text-gray-400"><%= @users.count %> users</p>
  </div>
  <div class="flex flex-wrap items-center gap-3">
    <% if params[:filter] == "archived" %>
      <%= link_to "Active Users", admin_users_path, class: "px-4 py-2 border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 font-bold text-xs uppercase tracking-wider hover:bg-gray-50 dark:hover:bg-gray-800 transition rounded-lg" %>
    <% else %>
      <%= link_to "Archived Users", admin_users_path(filter: "archived"), class: "px-4 py-2 border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 font-bold text-xs uppercase tracking-wider hover:bg-gray-50 dark:hover:bg-gray-800 transition rounded-lg" %>
    <% end %>
  </div>
</div>

<!-- Search -->
<div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg p-4 mb-6">
  <%= form_with url: admin_users_path, method: :get, class: "flex flex-col sm:flex-row items-stretch sm:items-center gap-3 sm:gap-4", data: { turbo: false } do |f| %>
    <div class="flex-1">
      <%= f.text_field :search, value: params[:search], placeholder: "Search by email...", class: "w-full px-4 py-2 border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
    </div>
    <%= f.submit "Search", class: "px-4 py-2 bg-emerald-500 text-black font-bold text-xs uppercase tracking-wider hover:bg-emerald-400 transition rounded-lg cursor-pointer" %>
    <% if params[:search].present? %>
      <%= link_to "Clear", admin_users_path, class: "px-4 py-2 text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 text-xs uppercase tracking-wider font-bold" %>
    <% end %>
  <% end %>
</div>

<!-- Bulk Action Bar (hidden by default, shown via JS when checkboxes are selected) -->
<div id="bulkActionBar" class="hidden bg-gray-900 dark:bg-gray-800 border border-gray-700 rounded-lg p-4 mb-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
  <div class="flex items-center gap-3">
    <span class="text-sm font-bold text-white"><span id="selectedCount">0</span> user(s) selected</span>
  </div>
  <div class="flex items-center gap-3">
    <button type="button" id="deselectAllBtn" class="px-4 py-2 text-gray-400 hover:text-white font-bold text-xs uppercase tracking-wider transition">
      Deselect All
    </button>
    <button type="button" id="openArchiveModalBtn" class="px-4 py-2 bg-red-600 text-white font-bold text-xs uppercase tracking-wider hover:bg-red-500 transition rounded-lg">
      Archive Selected
    </button>
  </div>
</div>

<!-- Users Table -->
<div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg overflow-hidden overflow-x-auto">
  <table class="w-full min-w-[700px]">
    <thead>
      <tr class="border-b border-gray-200 dark:border-gray-800">
        <th class="px-4 py-3 text-center w-10">
          <input type="checkbox" id="selectAll" class="w-4 h-4 rounded border-gray-300 dark:border-gray-600 text-emerald-500 focus:ring-emerald-500 dark:bg-gray-800 cursor-pointer">
        </th>
        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Email</th>
        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Group</th>
        <th class="px-6 py-3 text-center text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Tasks</th>
        <th class="px-6 py-3 text-center text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Role</th>
        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Joined</th>
        <th class="px-6 py-3 text-right text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
      <% @users.each do |user| %>
        <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition" data-user-id="<%= user.id %>">
          <td class="px-4 py-4 text-center">
            <% unless user == current_user %>
              <input type="checkbox" name="user_ids[]" value="<%= user.id %>" class="user-checkbox w-4 h-4 rounded border-gray-300 dark:border-gray-600 text-emerald-500 focus:ring-emerald-500 dark:bg-gray-800 cursor-pointer">
            <% end %>
          </td>
          <td class="px-6 py-4">
            <div class="flex items-center gap-3">
              <% if user.profile_photo.attached? %>
                <%= image_tag user.profile_photo, class: "w-8 h-8 rounded-full object-cover" %>
              <% else %>
                <div class="w-8 h-8 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-gray-500 text-xs font-bold"><%= user.email[0].upcase %></div>
              <% end %>
              <%= link_to user.email, admin_user_path(user), class: "text-sm font-medium text-gray-900 dark:text-white hover:text-emerald-500 transition" %>
            </div>
          </td>
          <td class="px-6 py-4">
            <p class="text-sm text-gray-600 dark:text-gray-400"><%= user.group || "—" %></p>
          </td>
          <td class="px-6 py-4 text-center">
            <p class="text-sm font-medium text-gray-900 dark:text-white"><%= user.tasks.count %></p>
          </td>
          <td class="px-6 py-4 text-center">
            <% if user.admin? %>
              <span class="px-2 py-1 text-xs font-bold bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 rounded uppercase tracking-wider">Admin</span>
            <% else %>
              <span class="text-xs text-gray-500">User</span>
            <% end %>
          </td>
          <td class="px-6 py-4">
            <% if user.archived? %>
              <span class="px-2 py-1 text-xs font-bold bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 rounded uppercase tracking-wider">Archived</span>
            <% else %>
              <span class="px-2 py-1 text-xs font-bold bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 rounded uppercase tracking-wider">Active</span>
            <% end %>
          </td>
          <td class="px-6 py-4">
            <p class="text-sm text-gray-600 dark:text-gray-400"><%= user.created_at.strftime("%b %d, %Y") %></p>
          </td>
          <td class="px-6 py-4 text-right">
            <div class="flex items-center justify-end gap-2">
              <%= link_to "Edit", edit_admin_user_path(user), class: "px-3 py-1 text-xs font-bold text-emerald-600 dark:text-emerald-400 hover:text-emerald-500 uppercase tracking-wider" %>
              <% unless user == current_user %>
                <% if user.archived? %>
                  <%= button_to "Unarchive", unarchive_admin_user_path(user), method: :post, class: "px-3 py-1 text-xs font-bold text-blue-600 dark:text-blue-400 hover:text-blue-500 uppercase tracking-wider" %>
                <% else %>
                  <%= button_to "Archive", admin_user_path(user), method: :delete, class: "px-3 py-1 text-xs font-bold text-red-600 dark:text-red-400 hover:text-red-500 uppercase tracking-wider", form: { data: { turbo_confirm: "Archive this user?" } } %>
                <% end %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @users.empty? %>
        <tr>
          <td colspan="8" class="px-6 py-12 text-center text-gray-500 text-sm">No users found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<!-- Confirmation Modal -->
<div id="archiveModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center">
  <!-- Backdrop -->
  <div id="archiveModalBackdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <!-- Modal -->
  <div class="relative bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-2xl w-full max-w-md mx-4 p-0 overflow-hidden">
    <!-- Header -->
    <div class="px-6 pt-6 pb-4">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
          <svg class="w-5 h-5 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-lg font-bold text-gray-900 dark:text-white">Archive Users</h3>
          <p class="text-sm text-gray-500">This action will archive <span id="modalUserCount" class="font-bold text-red-600 dark:text-red-400">0</span> user(s)</p>
        </div>
      </div>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-3">
        Archived users will no longer be able to sign in. Their data will be preserved but hidden from active user lists.
      </p>
    </div>
    <!-- Confirmation Input -->
    <div class="px-6 pb-4">
      <label for="confirmInput" class="block text-sm font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wide mb-2">
        Type <span class="text-red-600 dark:text-red-400">delete</span> to confirm
      </label>
      <input type="text" id="confirmInput" autocomplete="off" spellcheck="false"
        class="w-full px-4 py-3 border-2 border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 transition"
        placeholder="Type 'delete' to confirm">
      <p id="confirmError" class="hidden mt-2 text-xs font-bold text-red-600 dark:text-red-400 uppercase tracking-wide">
        Please type "delete" to confirm this action
      </p>
    </div>
    <!-- Actions -->
    <div class="px-6 py-4 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-200 dark:border-gray-700 flex items-center justify-end gap-3">
      <button type="button" id="cancelArchiveBtn"
        class="px-5 py-2.5 text-gray-700 dark:text-gray-300 font-bold text-xs uppercase tracking-wider hover:bg-gray-100 dark:hover:bg-gray-700 transition rounded-lg">
        Cancel
      </button>
      <form id="bulkArchiveForm" action="<%= bulk_archive_admin_users_path %>" method="post">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <div id="bulkArchiveUserIds"></div>
        <button type="submit" id="confirmArchiveBtn" disabled
          class="px-5 py-2.5 bg-red-600 text-white font-bold text-xs uppercase tracking-wider rounded-lg transition opacity-50 cursor-not-allowed">
          Archive Users
        </button>
      </form>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', initBulkArchive);
document.addEventListener('turbo:load', initBulkArchive);

function initBulkArchive() {
  const selectAll = document.getElementById('selectAll');
  const bulkActionBar = document.getElementById('bulkActionBar');
  const selectedCount = document.getElementById('selectedCount');
  const deselectAllBtn = document.getElementById('deselectAllBtn');
  const openArchiveModalBtn = document.getElementById('openArchiveModalBtn');
  const archiveModal = document.getElementById('archiveModal');
  const archiveModalBackdrop = document.getElementById('archiveModalBackdrop');
  const cancelArchiveBtn = document.getElementById('cancelArchiveBtn');
  const confirmInput = document.getElementById('confirmInput');
  const confirmError = document.getElementById('confirmError');
  const confirmArchiveBtn = document.getElementById('confirmArchiveBtn');
  const bulkArchiveUserIds = document.getElementById('bulkArchiveUserIds');
  const modalUserCount = document.getElementById('modalUserCount');

  if (!selectAll) return;

  function getCheckboxes() {
    return document.querySelectorAll('.user-checkbox');
  }

  function getSelectedIds() {
    return Array.from(getCheckboxes()).filter(cb => cb.checked).map(cb => cb.value);
  }

  function updateUI() {
    const selected = getSelectedIds();
    const count = selected.length;
    selectedCount.textContent = count;

    if (count > 0) {
      bulkActionBar.classList.remove('hidden');
    } else {
      bulkActionBar.classList.add('hidden');
    }

    const checkboxes = getCheckboxes();
    if (checkboxes.length > 0 && count === checkboxes.length) {
      selectAll.checked = true;
      selectAll.indeterminate = false;
    } else if (count > 0) {
      selectAll.checked = false;
      selectAll.indeterminate = true;
    } else {
      selectAll.checked = false;
      selectAll.indeterminate = false;
    }
  }

  selectAll.addEventListener('change', function() {
    getCheckboxes().forEach(cb => { cb.checked = this.checked; });
    updateUI();
  });

  document.addEventListener('change', function(e) {
    if (e.target.classList.contains('user-checkbox')) {
      updateUI();
    }
  });

  if (deselectAllBtn) {
    deselectAllBtn.addEventListener('click', function() {
      getCheckboxes().forEach(cb => { cb.checked = false; });
      selectAll.checked = false;
      selectAll.indeterminate = false;
      updateUI();
    });
  }

  if (openArchiveModalBtn) {
    openArchiveModalBtn.addEventListener('click', function() {
      const selected = getSelectedIds();
      if (selected.length === 0) return;

      modalUserCount.textContent = selected.length;

      bulkArchiveUserIds.innerHTML = '';
      selected.forEach(id => {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'user_ids[]';
        input.value = id;
        bulkArchiveUserIds.appendChild(input);
      });

      confirmInput.value = '';
      confirmError.classList.add('hidden');
      confirmArchiveBtn.disabled = true;
      confirmArchiveBtn.classList.add('opacity-50', 'cursor-not-allowed');
      confirmArchiveBtn.classList.remove('hover:bg-red-500');
      confirmInput.classList.remove('border-red-500', 'border-emerald-500');

      archiveModal.classList.remove('hidden');
      setTimeout(() => confirmInput.focus(), 100);
    });
  }

  function closeModal() {
    archiveModal.classList.add('hidden');
    confirmInput.value = '';
  }

  if (cancelArchiveBtn) cancelArchiveBtn.addEventListener('click', closeModal);
  if (archiveModalBackdrop) archiveModalBackdrop.addEventListener('click', closeModal);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !archiveModal.classList.contains('hidden')) {
      closeModal();
    }
  });

  if (confirmInput) {
    confirmInput.addEventListener('input', function() {
      const value = this.value.trim().toLowerCase();
      if (value === 'delete') {
        confirmArchiveBtn.disabled = false;
        confirmArchiveBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        confirmArchiveBtn.classList.add('hover:bg-red-500');
        confirmError.classList.add('hidden');
        confirmInput.classList.remove('border-red-500');
        confirmInput.classList.add('border-emerald-500');
      } else {
        confirmArchiveBtn.disabled = true;
        confirmArchiveBtn.classList.add('opacity-50', 'cursor-not-allowed');
        confirmArchiveBtn.classList.remove('hover:bg-red-500');
        confirmInput.classList.remove('border-emerald-500');
      }
    });
  }

  const bulkArchiveForm = document.getElementById('bulkArchiveForm');
  if (bulkArchiveForm) {
    bulkArchiveForm.addEventListener('submit', function(e) {
      const value = confirmInput.value.trim().toLowerCase();
      if (value !== 'delete') {
        e.preventDefault();
        confirmError.classList.remove('hidden');
        confirmInput.classList.add('border-red-500');
        confirmInput.focus();
      }
    });
  }
}
</script>
