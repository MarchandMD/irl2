<% content_for(:page_title, "Edit User") %>

<div class="mb-6">
  <%= link_to "← Back to User", admin_user_path(@user), class: "text-sm font-bold text-emerald-500 hover:text-emerald-400 uppercase tracking-wider" %>
</div>

<div class="max-w-3xl">
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg p-8">
    <div class="flex items-center gap-4 mb-8 pb-6 border-b border-gray-200 dark:border-gray-800">
      <% if @user.profile_photo.attached? %>
        <%= image_tag @user.profile_photo, class: "w-12 h-12 rounded-full object-cover" %>
      <% else %>
        <div class="w-12 h-12 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-gray-500 text-lg font-bold"><%= @user.email[0].upcase %></div>
      <% end %>
      <div>
        <p class="text-lg font-bold text-gray-900 dark:text-white"><%= @user.email %></p>
        <p class="text-sm text-gray-500">Joined <%= @user.created_at.strftime("%b %d, %Y") %></p>
      </div>
    </div>

    <%= form_with model: @user, url: admin_user_path(@user), method: :patch, class: "space-y-6" do |f| %>

      <% if @user.errors.any? %>
        <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
          <ul class="list-disc list-inside text-red-700 dark:text-red-400 text-sm space-y-1">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- Group -->
      <div>
        <%= f.label :group, "Group", class: "block text-sm font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wide mb-2" %>
        <%= f.select :group,
            [
              ["None", ""],
              ["Urban Nomads", "Urban Nomads"],
              ["Digital Alchemists", "Digital Alchemists"],
              ["Street Philosophers", "Street Philosophers"],
              ["Midnight Architects", "Midnight Architects"],
              ["Concrete Poets", "Concrete Poets"]
            ],
            {},
            class: "w-full px-4 py-3 border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition"
        %>
      </div>

      <!-- Admin Toggle -->
      <div>
        <label class="flex items-center gap-3 cursor-pointer">
          <%= f.check_box :admin, class: "w-5 h-5 rounded border-gray-300 dark:border-gray-600 text-emerald-500 focus:ring-emerald-500 dark:bg-gray-800" %>
          <div>
            <span class="text-sm font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wide">Admin Access</span>
            <p class="text-xs text-gray-500 mt-0.5">Grants full access to the admin dashboard and all management features.</p>
          </div>
        </label>
      </div>

      <!-- Submit -->
      <div class="flex items-center gap-4 pt-4">
        <%= f.submit "Update User", class: "px-6 py-3 bg-emerald-500 text-black font-bold text-xs uppercase tracking-wider hover:bg-emerald-400 transition rounded-lg cursor-pointer" %>
        <%= link_to "Cancel", admin_user_path(@user), class: "px-6 py-3 text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 font-bold text-xs uppercase tracking-wider" %>
      </div>
    <% end %>
  </div>
</div>
