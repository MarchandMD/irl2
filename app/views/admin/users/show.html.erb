<% content_for(:page_title, @user.email) %>

<div class="mb-6">
  <%= link_to "← Back to Users", admin_users_path, class: "text-sm font-bold text-emerald-500 hover:text-emerald-400 uppercase tracking-wider" %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- User Card -->
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg p-6 text-center">
      <% if @user.profile_photo.attached? %>
        <%= image_tag @user.profile_photo, class: "w-20 h-20 rounded-full object-cover mx-auto mb-4" %>
      <% else %>
        <div class="w-20 h-20 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-gray-500 text-2xl font-bold mx-auto mb-4"><%= @user.email[0].upcase %></div>
      <% end %>
      <h2 class="text-lg font-bold text-gray-900 dark:text-white"><%= @user.email.split('@').first %></h2>
      <p class="text-sm text-gray-500"><%= @user.email %></p>
      <% if @user.admin? %>
        <span class="inline-block mt-2 px-2 py-1 text-xs font-bold bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 rounded uppercase tracking-wider">Admin</span>
      <% end %>
    </div>

    <!-- Details -->
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg p-6">
      <h3 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Details</h3>
      <dl class="space-y-3">
        <div>
          <dt class="text-xs font-bold text-gray-500 uppercase tracking-wider">Group</dt>
          <dd class="text-sm text-gray-900 dark:text-white mt-1"><%= @user.group || "None" %></dd>
        </div>
        <div>
          <dt class="text-xs font-bold text-gray-500 uppercase tracking-wider">Tasks Created</dt>
          <dd class="text-sm text-gray-900 dark:text-white mt-1"><%= @tasks.count %></dd>
        </div>
        <div>
          <dt class="text-xs font-bold text-gray-500 uppercase tracking-wider">Comments</dt>
          <dd class="text-sm text-gray-900 dark:text-white mt-1"><%= @user.comments.count %></dd>
        </div>
        <div>
          <dt class="text-xs font-bold text-gray-500 uppercase tracking-wider">Joined</dt>
          <dd class="text-sm text-gray-900 dark:text-white mt-1"><%= @user.created_at.strftime("%b %d, %Y at %I:%M %p") %></dd>
        </div>
      </dl>
    </div>

    <!-- Actions -->
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg p-6 space-y-3">
      <h3 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Actions</h3>
      <%= link_to "Edit User", edit_admin_user_path(@user), class: "block w-full text-center px-4 py-2 bg-emerald-500 text-black font-bold text-xs uppercase tracking-wider hover:bg-emerald-400 transition rounded-lg" %>
      <%= link_to "View on Site", user_path(@user), class: "block w-full text-center px-4 py-2 border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 font-bold text-xs uppercase tracking-wider hover:bg-gray-50 dark:hover:bg-gray-800 transition rounded-lg", target: "_blank" %>
      <% unless @user == current_user %>
        <%= button_to "Delete User", admin_user_path(@user), method: :delete, class: "w-full px-4 py-2 bg-red-600 text-white font-bold text-xs uppercase tracking-wider hover:bg-red-500 transition rounded-lg", form: { data: { turbo_confirm: "Are you sure? This deletes all their data." } } %>
      <% end %>
    </div>
  </div>

  <!-- Main Content -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Tasks -->
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-800">
        <h3 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider">Tasks (<%= @tasks.count %>)</h3>
      </div>
      <div class="divide-y divide-gray-200 dark:divide-gray-800">
        <% @tasks.each do |task| %>
          <div class="px-6 py-3 flex items-center justify-between">
            <div class="min-w-0 flex-1">
              <%= link_to task.title, admin_task_path(task), class: "text-sm font-medium text-gray-900 dark:text-white hover:text-emerald-500 truncate block" %>
              <p class="text-xs text-gray-500"><%= task.status.humanize %> &middot; <%= time_ago_in_words(task.created_at) %> ago</p>
            </div>
          </div>
        <% end %>
        <% if @tasks.empty? %>
          <div class="px-6 py-8 text-center text-gray-500 text-sm">No tasks created.</div>
        <% end %>
      </div>
    </div>

    <!-- Recent Comments -->
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-800">
        <h3 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider">Recent Comments</h3>
      </div>
      <div class="divide-y divide-gray-200 dark:divide-gray-800">
        <% @comments.each do |comment| %>
          <div class="px-6 py-3">
            <div class="flex items-center justify-between mb-1">
              <p class="text-xs text-gray-500"><%= time_ago_in_words(comment.created_at) %> ago on <%= comment.commentable_type %></p>
              <%= button_to "Delete", admin_comment_path(comment), method: :delete, class: "text-xs font-bold text-red-500 hover:text-red-400 uppercase tracking-wider", form: { data: { turbo_confirm: "Delete this comment?" } } %>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400"><%= comment.content.truncate(200) %></p>
          </div>
        <% end %>
        <% if @comments.empty? %>
          <div class="px-6 py-8 text-center text-gray-500 text-sm">No comments.</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
